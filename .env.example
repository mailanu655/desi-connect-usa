# ===== Desi Connect USA - Environment Configuration =====

# --- Teable (Primary Database) ---
TEABLE_BASE_URL=https://app.teable.io
TEABLE_API_KEY=your_teable_api_key
TEABLE_TABLE_USERS=tblXXXXXXXXXX
TEABLE_TABLE_BUSINESSES=tblXXXXXXXXXX
TEABLE_TABLE_JOBS=tblXXXXXXXXXX
TEABLE_TABLE_NEWS=tblXXXXXXXXXX
TEABLE_TABLE_DEALS=tblXXXXXXXXXX
TEABLE_TABLE_CONSULTANCIES=tblXXXXXXXXXX
TEABLE_TABLE_EVENTS=tblXXXXXXXXXX
TEABLE_TABLE_REVIEWS=tblXXXXXXXXXX

# --- NoCodeBackend (API Cache Layer) ---
NOCODEBACKEND_BASE_URL=https://api.nocodebackend.com/v1
NOCODEBACKEND_API_KEY=your_nocodebackend_api_key
NOCODEBACKEND_PROJECT_ID=your_project_id

# --- Twilio (WhatsApp Business API) ---
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=+14155238886
TWILIO_WEBHOOK_URL=https://your-domain.com/api/whatsapp/webhook

# --- AI / NLP ---
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
AI_PROVIDER=openai

# --- Tavily (Content Aggregation) ---
TAVILY_API_KEY=tvly-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TAVILY_FETCH_INTERVAL_HOURS=4

# --- Authentication ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXTAUTH_SECRET=your_nextauth_secret_minimum_32_chars
NEXTAUTH_URL=http://localhost:3000

# --- Email (Emailit - Magic Link) ---
EMAILIT_API_KEY=your_emailit_api_key
EMAILIT_SENDER=noreply@desiconnectusa.com

# --- General ---
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
