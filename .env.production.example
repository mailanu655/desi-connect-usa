# ─────────────────────────────────────────────────────────────
# Desi Connect USA — Production Environment Template
# Copy to .env and fill in values before deployment
# ─────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# ── Teable Database ────────────────────────────────────────
TEABLE_API_URL=
TEABLE_API_KEY=
TEABLE_TABLE_USERS=
TEABLE_TABLE_BUSINESSES=
TEABLE_TABLE_JOBS=
TEABLE_TABLE_NEWS=
TEABLE_TABLE_DEALS=
TEABLE_TABLE_CONSULTANCIES=
TEABLE_TABLE_EVENTS=
TEABLE_TABLE_REVIEWS=

# ── Redis (session store) ──────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Twilio (WhatsApp) ─────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
TWILIO_WEBHOOK_URL=

# ── AI / NLP ──────────────────────────────────────────────
INTENT_AI_PROVIDER=anthropic
INTENT_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Tavily (web search) ───────────────────────────────────
TAVILY_API_KEY=

# ── Authentication (NextAuth) ─────────────────────────────
NEXTAUTH_URL=
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Emailit) ───────────────────────────────────────
EMAILIT_API_KEY=
