{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@desi-connect/shared": ["packages/shared/src"],
      "@desi-connect/shared/*": ["packages/shared/src/*"],
      "@desi-connect/database": ["packages/database/src"],
      "@desi-connect/database/*": ["packages/database/src/*"],
      "@desi-connect/middleware": ["packages/middleware/src"],
      "@desi-connect/middleware/*": ["packages/middleware/src/*"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "packages/web"]
}
